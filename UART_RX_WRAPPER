library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;

entity UART_10Byte_XOR_80Bit is
  generic (
    g_CLKS_PER_BIT : integer := 10417 -- Preset for 9600 Baud on 100 MHz clock
  );
  port (
    i_Clk           : in  std_logic;
    i_Rst           : in  std_logic;
    i_RX_Serial     : in  std_logic;
    
    -- Status Indicators
    o_Packet_Valid  : out std_logic;                  -- Pulses high for 1 cycle on success
    o_Header_Error  : out std_logic;                  -- High if Byte 0 is not 0xAA
    o_Csum_Error    : out std_logic;                  -- High if Byte 9 XOR check fails
    
    -- Stored 10-byte complete packet (80 bits total)
    o_Packet_Data   : out std_logic_vector(79 downto 0) 
  );
end UART_10Byte_XOR_80Bit;

architecture Behavioral of UART_10Byte_XOR_80Bit is

  component UART_RX is
    generic ( g_CLKS_PER_BIT : integer := 10417 );
    port (
      i_Clk       : in  std_logic;
      i_RX_Serial : in  std_logic;
      o_RX_DV     : out std_logic;
      o_RX_Byte   : out std_logic_vector(7 downto 0)
    );
  end component;

  signal w_RX_DV       : std_logic;
  signal w_RX_Byte     : std_logic_vector(7 downto 0);
  signal r_RX_Sync     : std_logic_vector(1 downto 0) := "11";

  -- Parser States
  type t_Parse_State is (s_Wait_Header, s_Collect_Payload, s_Verify_Checksum, s_Packet_Done);
  signal r_State : t_Parse_State := s_Wait_Header;

  -- Storage Array for all 10 Bytes (Indexes 0 to 9)
  type t_Packet_Storage is array (0 to 9) of std_logic_vector(7 downto 0);
  signal r_Storage     : t_Packet_Storage := (others => (others => '0'));
  
  signal r_Byte_Index  : integer range 0 to 9 := 0;
  signal r_Checksum    : std_logic_vector(7 downto 0) := (others => '0');

  signal r_Header_Error : std_logic := '0';
  signal r_Csum_Error   : std_logic := '0';
  signal r_Packet_Valid : std_logic := '0';

begin

  -- Double Flop Synchronizer for Metastability
  p_Synchronizer : process (i_Clk)
  begin
    if rising_edge(i_Clk) then
      r_RX_Sync <= r_RX_Sync(0) & i_RX_Serial;
    end if;
  end process p_Synchronizer;

  -- Base UART Receiver Instance
  UART_RX_Inst : UART_RX
    generic map ( g_CLKS_PER_BIT => g_CLKS_PER_BIT )
    port map (
      i_Clk       => i_Clk,
      i_RX_Serial => r_RX_Sync(1),
      o_RX_DV     => w_RX_DV,
      o_RX_Byte   => w_RX_Byte
    );

  -- Protocol Parsing State Machine
  p_Frame_Parser : process (i_Clk)
  begin
    if rising_edge(i_Clk) then
      if i_Rst = '1' then
        r_State        <= s_Wait_Header;
        r_Byte_Index   <= 0;
        r_Checksum     <= (others => '0');
        r_Header_Error <= '0';
        r_Csum_Error   <= '0';
        r_Packet_Valid <= '0';
        r_Storage      <= (others => (others => '0'));
      else
        r_Packet_Valid <= '0'; -- Clear single-cycle valid pulse

        case r_State is

          -- BYTE 0: Expecting 0xAA Header
          when s_Wait_Header =>
            if w_RX_DV = '1' then
              if w_RX_Byte = X"AA" then
                r_Storage(0)   <= w_RX_Byte;       -- Store Header at Index 0
                r_Header_Error <= '0';
                r_Csum_Error   <= '0';
                r_Checksum     <= X"AA";           -- Initialize checksum with 0xAA
                r_Byte_Index   <= 1;               -- Set up next byte placement index
                r_State        <= s_Collect_Payload;
              else
                r_Header_Error <= '1';            -- Flag invalid header
                r_State        <= s_Wait_Header;
              end if;
            end if;

          -- BYTES 1 to 8: Accumulate Payload & Calculate Running XOR
          when s_Collect_Payload =>
            if w_RX_DV = '1' then
              r_Storage(r_Byte_Index) <= w_RX_Byte; -- Stores data bits sequentially into array
              
              -- XOR Checksum Math
              r_Checksum <= r_Checksum xor w_RX_Byte; 
              
              if r_Byte_Index = 8 then
                r_State <= s_Verify_Checksum;     -- 9 bytes tracked total (0 to 8), check checksum next
              end if;
              
              r_Byte_Index <= r_Byte_Index + 1;
            end if;

          -- BYTE 9: Compare against calculated XOR Checksum
          when s_Verify_Checksum =>
            if w_RX_DV = '1' then
              r_Storage(9) <= w_RX_Byte;           -- Store the Checksum byte at Index 9
              
              if w_RX_Byte = r_Checksum then
                r_Csum_Error   <= '0';
                r_Packet_Valid <= '1';            -- Full 10-byte packet is valid
                r_State        <= s_Packet_Done;
              else
                r_Csum_Error   <= '1';            -- Checksum mismatch error
                r_State        <= s_Wait_Header;  -- Dump packet data, restart parse structure
              end if;
            end if;

          -- End of Packet Handling
          when s_Packet_Done =>
            r_State <= s_Wait_Header;

          when others =>
            r_State <= s_Wait_Header;
        end case;
      end if;
    end if;
  end process p_Frame_Parser;

  -- Signal Assignment
  o_Packet_Valid <= r_Packet_Valid;
  o_Header_Error <= r_Header_Error;
  o_Csum_Error   <= r_Csum_Error;
  
  -- Output Bus Assignment (Flattened 80-bit structure spanning all 10 bytes)
  o_Packet_Data <= r_Storage(9) & r_Storage(8) & r_Storage(7) & r_Storage(6) & 
                   r_Storage(5) & r_Storage(4) & r_Storage(3) & r_Storage(2) & 
                   r_Storage(1) & r_Storage(0);

end Behavioral;
