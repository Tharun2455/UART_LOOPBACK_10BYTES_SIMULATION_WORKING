library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;

entity UART_10Byte_Loopback_Top is
  generic (
    g_CLKS_PER_BIT : integer := 10417 
  );
  port (
    i_Clk           : in  std_logic;
    i_Rst           : in  std_logic;
    i_RX_Serial     : in  std_logic;                  
    o_TX_Serial     : out std_logic;                  
    o_Loopback_Done : out std_logic;                  
    o_Header_Error  : out std_logic;                  
    o_Csum_Error    : out std_logic                   
  );
end UART_10Byte_Loopback_Top;

architecture Structural of UART_10Byte_Loopback_Top is

  component UART_10Byte_XOR_80Bit is
    generic ( g_CLKS_PER_BIT : integer := 10417 );
    port (
      i_Clk           : in  std_logic;
      i_Rst           : in  std_logic;
      i_RX_Serial     : in  std_logic;
      o_Packet_Valid  : out std_logic;
      o_Header_Error  : out std_logic;
      o_Csum_Error    : out std_logic;
      o_Packet_Data   : out std_logic_vector(79 downto 0)
    );
  end component;

  component UART_10Byte_XOR_80Bit_TX is
    generic ( g_CLKS_PER_BIT : integer := 10417 );
    port (
      i_Clk         : in  std_logic;
      i_Rst         : in  std_logic;
      i_TX_Start    : in  std_logic;
      o_TX_Active   : out std_logic;
      o_TX_Serial   : out std_logic;
      i_Packet_Data : in  std_logic_vector(79 downto 0)
    );
  end component;

  signal w_Packet_Valid   : std_logic;
  signal r_TX_Start_Reg   : std_logic := '0'; -- Pipeline delay to prevent delta-cycle drops
  signal w_Packet_Data    : std_logic_vector(79 downto 0);
  signal w_TX_Active      : std_logic;

begin

  -- Delay loopback trigger by 1 cycle to allow RX bus outputs to settle
  p_Pipeline_Trigger : process(i_Clk)
  begin
    if rising_edge(i_Clk) then
      if i_Rst = '1' then
        r_TX_Start_Reg <= '0';
      else
        r_TX_Start_Reg <= w_Packet_Valid;
      end if;
    end if;
  end process p_Pipeline_Trigger;

  UART_RX_Wrapper_Inst : UART_10Byte_XOR_80Bit
    generic map ( g_CLKS_PER_BIT => g_CLKS_PER_BIT )
    port map (
      i_Clk           => i_Clk,
      i_Rst           => i_Rst,
      i_RX_Serial     => i_RX_Serial,
      o_Packet_Valid  => w_Packet_Valid,   
      o_Header_Error  => o_Header_Error,
      o_Csum_Error    => o_Csum_Error,
      o_Packet_Data   => w_Packet_Data     
    );

  UART_TX_Wrapper_Inst : UART_10Byte_XOR_80Bit_TX
    generic map ( g_CLKS_PER_BIT => g_CLKS_PER_BIT )
    port map (
      i_Clk         => i_Clk,
      i_Rst         => i_Rst,
      i_TX_Start    => r_TX_Start_Reg,     -- Uses pipelined safe trigger signal
      o_TX_Active   => w_TX_Active,
      o_TX_Serial   => o_TX_Serial,
      i_Packet_Data => w_Packet_Data       
    );

  o_Loopback_Done <= r_TX_Start_Reg;

end Structural;
